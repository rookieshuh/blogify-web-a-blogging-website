# Required: Secret key used to sign JWT tokens. Use a long, random string.
JWT_SECRET=your_strong_random_secret_here

# Optional: MongoDB connection URI (defaults to local instance)
MONGODB_URI=mongodb://127.0.0.1:27017/blogApp

# Optional: Comma-separated list of allowed CORS origins (defaults to http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Optional: Server port (defaults to 3000)
PORT=3000
